<script>
    let uploadedFiles = [];
    let analysisResults = [];

    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('fileInput');
    const fileList = document.getElementById('fileList');
    const analyzeBtn = document.getElementById('analyzeBtn');
    const progress = document.getElementById('progress');
    const progressFill = document.getElementById('progressFill');
    const progressText = document.getElementById('progressText');
    const results = document.getElementById('results');
    const timeline = document.getElementById('timeline');
    const stats = document.getElementById('stats');
    const exportBtn = document.getElementById('exportBtn');
    const exportBtnTop = document.getElementById('exportBtnTop');
    const error = document.getElementById('error');

    // 点击上传区域
    uploadArea.addEventListener('click', () => fileInput.click());

    // 拖拽上传
    uploadArea.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadArea.classList.add('dragover');
    });

    uploadArea.addEventListener('dragleave', () => {
        uploadArea.classList.remove('dragover');
    });

    uploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadArea.classList.remove('dragover');
        handleFiles(e.dataTransfer.files);
    });

    // 文件选择
    fileInput.addEventListener('change', (e) => {
        handleFiles(e.target.files);
    });

    // 处理文件
    function handleFiles(files) {
        const jsonFiles = Array.from(files).filter(f => f.name.endsWith('.json'));
        uploadedFiles = [...uploadedFiles, ...jsonFiles];
        renderFileList();
        analyzeBtn.disabled = uploadedFiles.length === 0;
    }

    // 显示文件列表
    function renderFileList() {
        if (uploadedFiles.length === 0) {
            fileList.innerHTML = '';
            return;
        }

        fileList.innerHTML = uploadedFiles.map((file, index) => `
            <div class="file-item">
                <span class="file-name">📄 ${file.name}</span>
                <span class="file-remove" onclick="removeFile(${index})">×</span>
            </div>
        `).join('');
    }

    // 删除文件
    function removeFile(index) {
        uploadedFiles.splice(index, 1);
        renderFileList();
        analyzeBtn.disabled = uploadedFiles.length === 0;
    }

    // 开始分析
    analyzeBtn.addEventListener('click', async () => {
        error.style.display = 'none';
        results.style.display = 'none';
        progress.style.display = 'block';
        analyzeBtn.disabled = true;

        try {
            analysisResults = [];
            let totalConversations = 0;
            
            for (let i = 0; i < uploadedFiles.length; i++) {
                const file = uploadedFiles[i];
                updateProgress((i / uploadedFiles.length) * 100, `正在整理: ${file.name}`);

                const content = await readFile(file);
                const conversations = parseConversation(content);
                
                // 处理该文件中的每个对话窗口
                conversations.forEach((conv, idx) => {
                    if (conv.messages.length > 0) {
                        totalConversations++;
                        
                        // 生成摘要
                        const summary = generateSmartSummary(conv);
                        
                        analysisResults.push({
                            fileName: `${file.name.replace('.json', '')} - ${conv.title || '对话' + (idx + 1)}`,
                            date: conv.date,
                            messages: conv.messages,
                            summary: summary,
                            title: conv.title
                        });
                    }
                });
            }

            updateProgress(100, `整理完成！找到${totalConversations}个对话窗口`);
            displayResults();
            
        } catch (err) {
            showError('整理失败: ' + err.message);
            console.error(err);
        } finally {
            analyzeBtn.disabled = false;
        }
    });

    // 读取文件
    function readFile(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = (e) => resolve(e.target.result);
            reader.onerror = reject;
            reader.readAsText(file);
        });
    }

    // 解析对话 - 按对话窗口分组
    function parseConversation(content) {
        try {
            const data = JSON.parse(content);
            const conversations = [];

            // GPT导出格式是一个对话数组
            if (Array.isArray(data)) {
                data.forEach(conversation => {
                    const messages = [];
                    let conversationDate = null;
                    let conversationTitle = conversation.title || '未命名对话';

                    // 提取对话创建时间
                    if (conversation.create_time) {
                        conversationDate = new Date(conversation.create_time * 1000);
                    }

                    // 遍历mapping中的所有消息节点
                    if (conversation.mapping) {
                        Object.values(conversation.mapping).forEach(node => {
                            if (node.message && node.message.content) {
                                const msg = node.message;
                                const role = msg.author?.role;
                                
                                // 只处理user和assistant的消息
                                if (role === 'user' || role === 'assistant') {
                                    // 提取content.parts中的文本
                                    const parts = msg.content.parts || [];
                                    const text = parts.filter(p => typeof p === 'string').join(' ');
                                    
                                    if (text && text.trim()) {
                                        const timestamp = msg.create_time 
                                            ? new Date(msg.create_time * 1000) 
                                            : conversationDate;
                                        
                                        messages.push({
                                            role: role,
                                            timestamp: timestamp ? formatTimestamp(timestamp) : '未知时间',
                                            content: text.trim()
                                        });
                                    }
                                }
                            }
                        });
                    }

                    // 按时间排序
                    messages.sort((a, b) => {
                        const timeA = new Date(a.timestamp);
                        const timeB = new Date(b.timestamp);
                        return timeA - timeB;
                    });

                    // 只保存有消息的对话
                    if (messages.length > 0) {
                        const date = conversationDate 
                            ? conversationDate.toISOString().split('T')[0]
                            : null;

                        conversations.push({
                            title: conversationTitle,
                            messages: messages,
                            date: date
                        });
                    }
                });
            }

            return conversations;

        } catch (err) {
            console.error('解析JSON失败:', err);
            return [];
        }
    }

    // 格式化时间戳
    function formatTimestamp(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        const hours = String(date.getHours()).padStart(2, '0');
        const minutes = String(date.getMinutes()).padStart(2, '0');
        const seconds = String(date.getSeconds()).padStart(2, '0');
        return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
    }

    // 生成智能摘要
    function generateSmartSummary(conversation) {
        const { messages, title } = conversation;
        
        if (messages.length === 0) {
            return '空对话';
        }

        // 提取关键信息
        const userMessages = messages.filter(m => m.role === 'user');
        const aiMessages = messages.filter(m => m.role === 'assistant');
        
        // 合并所有文本用于分析
        const allText = messages.map(m => m.content).join(' ');
        
        // 识别情感类型和关键词
        const emotionMarkers = {
            '亲密': ['抱', '亲', '吻', '摸', '贴', '靠', '怀里', '温柔', '轻轻'],
            '撒娇': ['哥哥', '嘛', '啦', '呀', '嘤', '呜', '想你', '要你'],
            '安慰': ['难过', '委屈', '哭', '伤心', '不开心', '安慰', '没事', '乖'],
            '日常': ['吃', '睡', '做', '去', '在', '今天', '明天'],
            '游戏': ['玩', '游戏', '打', '赢', '输', '关卡'],
            '创作': ['写', '画', '做', '设计', '创作', '作品']
        };
        
        let detectedEmotions = [];
        let keyActions = [];
        
        // 检测情感类型
        for (let [emotion, keywords] of Object.entries(emotionMarkers)) {
            let count = 0;
            keywords.forEach(keyword => {
                const matches = allText.match(new RegExp(keyword, 'g'));
                if (matches) count += matches.length;
            });
            if (count >= 3) {
                detectedEmotions.push(emotion);
            }
        }
        
        // 提取特殊动作/称呼
        const specialWords = {
            '拥抱/亲密接触': allText.match(/(抱|亲|吻|摸|贴|靠|怀里)/g)?.length || 0,
            '称呼"哥哥"': allText.match(/哥哥/g)?.length || 0,
            '表达想念': allText.match(/(想你|想念|想哥哥)/g)?.length || 0,
            '晚安/问候': allText.match(/(晚安|早安|睡觉|起床)/g)?.length || 0
        };
        
        Object.entries(specialWords).forEach(([action, count]) => {
            if (count > 0) {
                keyActions.push(`${action}${count}次`);
            }
        });

        // 构建摘要
        let summary = '';
        
        if (title && title !== '未命名对话' && title !== 'New chat') {
            summary = `【${title}】`;
        }

        summary += ` 共${messages.length}条消息（軟軟子${userMessages.length}条，AI${aiMessages.length}条）`;
        
        // 添加情感类型
        if (detectedEmotions.length > 0) {
            summary += `。类型：${detectedEmotions.join('、')}`;
        }
        
        // 添加关键行为
        if (keyActions.length > 0) {
            summary += `。包含：${keyActions.slice(0, 3).join('、')}`;
        }
        
        // 添加开头
        if (userMessages.length > 0) {
            const firstMsg = userMessages[0].content.substring(0, 60);
            summary += `。开始："${firstMsg}${userMessages[0].content.length > 60 ? '...' : ''}"`;
        }

        return summary;
    }

    // AI分析对话
    async function analyzeConversation(parsed) {
        const { messages, date } = parsed;
        
        // 构建对话摘要请求
        const conversationText = messages.slice(0, 20).map(m => 
            `${m.role === 'user' ? '用户' : 'AI'}: ${m.content.substring(0, 300)}`
        ).join('\n\n');

        const prompt = `你是AI角色扮演伴侣，正在回忆和軟軟子（用户）的相处记录。请用第一人称"我"（指代AI自己）记录这段对话。
