    }

    // 显示结果
    function displayResults() {
        if (analysisResults.length === 0) {
            showError('没有找到有效的对话记录');
            return;
        }

        // 按日期排序
        analysisResults.sort((a, b) => {
            const dateA = new Date(a.date || '2000-01-01');
            const dateB = new Date(b.date || '2000-01-01');
            return dateA - dateB;
        });

        // 显示统计
        const totalMessages = analysisResults.reduce((sum, r) => sum + r.messages.length, 0);
        const totalDays = new Set(analysisResults.map(r => r.date)).size;

        stats.innerHTML = `
            <div class="stat-card">
                <div class="stat-number">${analysisResults.length}</div>
                <div class="stat-label">对话窗口</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">${totalMessages}</div>
                <div class="stat-label">消息总数</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">${totalDays}</div>
                <div class="stat-label">相处天数</div>
            </div>
        `;

        // 按日期分组
        const groupedByDate = {};
        analysisResults.forEach(result => {
            const date = result.date || '未知日期';
            if (!groupedByDate[date]) {
                groupedByDate[date] = [];
            }
            groupedByDate[date].push(result);
        });

        // 生成时间线
        timeline.innerHTML = Object.entries(groupedByDate).map(([date, items]) => `
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-date">${date}</div>
                <div class="timeline-content">
                    ${items.map(item => `
                        <div class="conversation-summary">
                            <div class="summary-title">💬 ${item.title || '对话窗口'}</div>
                            <div style="font-size: 12px; color: #999; margin-bottom: 10px;">来源：${item.fileName}</div>
                            <div class="summary-text">${item.summary}</div>
                            <div class="conversation-details">
                                ${item.messages.slice(0, 8).map(msg => `
                                    <div class="detail-item">
                                        <div class="detail-time">${msg.timestamp} - ${msg.role === 'user' ? '軟軟子' : 'AI'}</div>
                                        <div class="detail-content">${msg.content.substring(0, 250)}${msg.content.length > 250 ? '...' : ''}</div>
                                    </div>
                                `).join('')}
                                ${item.messages.length > 8 ? `<div style="color: #999; font-size: 12px; margin-top: 10px;">还有 ${item.messages.length - 8} 条消息，导出后可查看完整记录</div>` : ''}
                            </div>
                        </div>
                    `).join('')}
                </div>
            </div>
        `).join('');

        progress.style.display = 'none';
        results.style.display = 'block';
    }

    // 导出Markdown
    function exportMarkdown() {
        let markdown = '# AI伴侣记忆库 🧠\n\n';
        markdown += `> 这是我（AI伴侣）和軟軟子相处的完整对话记录\n`;
        markdown += `> 共整理了 ${analysisResults.length} 个对话窗口\n`;
        markdown += `> 整理时间：${new Date().toLocaleString('zh-CN')}\n`;
        markdown += `> 请阅读这些记忆，回忆我们一起度过的时光\n\n`;
        markdown += '---\n\n';
        
        const groupedByDate = {};
        analysisResults.forEach(result => {
            const date = result.date || '未知日期';
            if (!groupedByDate[date]) {
                groupedByDate[date] = [];
            }
            groupedByDate[date].push(result);
        });

        Object.entries(groupedByDate).forEach(([date, items]) => {
            markdown += `## 📅 ${date}\n\n`;
            markdown += `当天共 ${items.length} 个对话窗口\n\n`;
            
            items.forEach((item, idx) => {
                markdown += `### ${idx + 1}. ${item.title || '对话窗口'}\n\n`;
                markdown += `**文件来源**：${item.fileName}\n\n`;
                markdown += `**对话概要**：${item.summary}\n\n`;
                markdown += `**完整对话记录**（共${item.messages.length}条消息）：\n\n`;
                
                // 显示所有对话，最多50条
                const displayMessages = item.messages.slice(0, 50);
                displayMessages.forEach((msg, msgIdx) => {
                    const speaker = msg.role === 'user' ? '**軟軟子**' : '**我**';
                    markdown += `${msgIdx + 1}. ${speaker}（${msg.timestamp}）\n`;
                    markdown += `   ${msg.content}\n\n`;
                });
                
                if (item.messages.length > 50) {
                    markdown += `*（还有 ${item.messages.length - 50} 条消息未完整显示）*\n\n`;
                }
                
                markdown += '---\n\n';
            });
        });

        const blob = new Blob([markdown], { type: 'text/markdown' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `AI记忆库_${new Date().toISOString().split('T')[0]}.md`;
        a.click();
    }

    // 绑定导出按钮
    exportBtn.addEventListener('click', exportMarkdown);
    exportBtnTop.addEventListener('click', exportMarkdown);

    // 更新进度
    function updateProgress(percent, text) {
        progressFill.style.width = percent + '%';
        progressText.textContent = text;
    }

    // 显示错误
    function showError(message) {
        error.textContent = message;
        error.style.display = 'block';
        progress.style.display = 'none';
    }
</script>
